    <style>
        .overlay-box {
            position: relative;
        }
        .overlay-box:after {
            background: hsla(0,0%,100%,.4);
            bottom: 0;
            content: "";
            left: 0;
            position: absolute;
            right: 0;
            top: 0;
            z-index: 900;
        }
        .alert {
            background-color: #ffefd9;
            font-size: 1rem;
            margin: 0 0 20px;
            padding: .6666rem 1rem;
        }
        #fromAddressSuggest,
        #toAddressSuggest {
            position: absolute;
            display: none;
            background-color: #fff;
            border-radius: 8px;
            color: #000;
            left: 0;
            top: 100%;
            margin-top: 4px;
            box-shadow: 0 5px 46px #0000001f,0 7px 15px #0000001f;
            height: 300px;
            overflow-y: auto;
            z-index: 3;
        }
        .suggest-list {
            margin: 0;
            padding: 0;
            height: 100%;
            list-style-type: none;
        }
        .suggest-list li {
            padding: 8px 15px;
        }
        .suggest-list li:hover {
            background-color: #f4f4f4;
        }
        .tab {
            list-style: none;
            display: flex;
            flex-direction: row;
            flex-wrap: nowrap;
            height: 32px;
            line-height: normal;
            padding: 0;
            margin-bottom: 10px;
        }
    </style>
