{% extends "base.html.twig" %}

{% block title %}Главная{% endblock %}

{% block body %}
    <h1>Поиск грузов</h1>

    <a class="button" href="{{ path('cargo.create') }}">Добавить</a>

    <form action="{{ path('cargo.index') }}" method="GET" class="filter" id="filter">
        <div class="filter__row">
            <div class="filter__block">
                <div class="filter__element">
                    <label>Откуда</label>
                    <input type="text" class="filter__input" id="fromAddressInput" name="fromAddress" {% if filter and filter.fromAddress is defined %}value="{{ filter.fromAddress }}"{% endif %}>
                    <div id="fromAddressSuggest">
                        <ul class="suggest-list"></ul>
                    </div>
                </div>
                <div class="filter__element filter__element-radius">
                    <label>Радиус</label>
                    <input type="text" class="filter__input" id="fromRadius" name="fromRadius" placeholder="км" disabled {% if filter and filter.fromRadius is defined %}value="{{ filter.fromRadius }}"{% endif %}>
                </div>
                <div class="filter__swap">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M6.99 11L3 15l3.99 4v-3H14v-2H6.99v-3zM21 9l-3.99-4v3H10v2h7.01v3L21 9z"></path>
                        <path d="M0 0h24v24H0z" fill="none"></path>
                    </svg>
                </div>
                <div class="filter__element">
                    <label>Куда</label>
                    <input type="text" class="filter__input" id="toAddressInput" name="toAddress" {% if filter and filter.toAddress is defined %}value="{{ filter.toAddress }}"{% endif %}>
                    <div id="toAddressSuggest">
                        <ul class="suggest-list"></ul>
                    </div>
                </div>
                <div class="filter__element filter__element-radius">
                    <label>Радиус</label>
                    <input type="text" class="filter__input" id="toRadius" name="toRadius" placeholder="км" disabled {% if filter and filter.toRadius is defined %}value="{{ filter.toRadius }}"{% endif %}>
                </div>
            </div>
            <div class="filter__block">
                <div class="filter__element">
                    <label>Вес</label>
                    <input type="text" class="filter__input" name="weight" {% if filter and filter.weight is defined %}value="{{ filter.weight }}"{% endif %}>
                </div>
                <div class="filter__element">
                    <label>Объем</label>
                    <input type="text" class="filter__input" name="volume" {% if filter and filter.volume is defined %}value="{{ filter.volume }}"{% endif %}>
                </div>
            </div>
        </div>
        <div class="filter__row">
            <button type="submit" class="button">Найти</button>
        </div>
    </form>
    {% if list|length > 0 %}
        <div class="meta">
            <h2>Найдено {{ totalCount }} грузов</h2>
            <div class="meta-right">
                <div class="sort">
                    <label>Упорядочить по </label>
                    <select name="order_by" id="">
                        <option value="">времени добавления</option>
                    </select>
                </div>
                {{ include('common/pagination.html.twig',  { page: page, lastPage: lastPage, url: 'cargo.index' }) }}
            </div>

        </div>

        <div class="table">
            <div class="row row__header">
                <div class="table-item">Откуда</div>
                <div class="table-item">Куда</div>
                <div class="table-item">Груз</div>
                <div class="table-item">Ставка</div>
                <div class="table-item">Готов</div>
                <div class="table-item">Транспорт</div>
            </div>
            {% for order in list %}
                <div class="row">
                    <div class="table-item">{{ order.fromAddress }}</div>
                    <div class="table-item">{{ order.toAddress }}</div>
                    <div class="table-item">
                        {{ order.weight }}т. {{ order.volume }}м3 {{ order.getCargoTypeName() }}
                    </div>
                    <div class="table-item">
                        {% if order.isAgreedPrice %}
                            {{ order.price }} руб
                        {% else %}
                            запрос ставки
                        {% endif %}
                    </div>
                    <div class="table-item">Готов</div>
                    <div class="table-item">Транспорт</div>
                    <div class="table-contact">
                        {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                            {{ order.user.email }}
                        {% else %}
                            <div class="button-empty">показать контакты и ставку</div>
                            <div>
                                Доступно <b>бесплатно</b> после быстрой регистрации
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>

    {% else %}
        <div>No orders have been posted yet.</div>
    {% endif %}
    <style>
        .filter {
            box-shadow: 0 0 6px rgba(7, 24, 41, 0.02),0 2px 4px rgba(7, 24, 41, 0.08);
            padding: 20px;
            margin-bottom: 20px;
            background-color: #f1f1f1;
        }
        .filter__row {
            display: flex;
            gap: 24px;
            margin-bottom: 15px;
        }
        .filter__block {
            display: flex;
        }
        .filter__element {
            position: relative;
            display: flex;
            flex-direction: column;
        }
        .filter__swap {
            display: flex;
            margin: 28px 10px 0;
        }
        .filter__swap svg {
            width: 24px;
            height: 32px;
            fill: #478cc8;
            transition: all .2s ease-in-out;
        }
        .filter__element-radius {
            width: 72px;
        }
        .filter__input {
            border-radius: 0;
        }
        #fromAddressSuggest,
        #toAddressSuggest {
            position: absolute;
            display: none;
            background-color: #fff;
            border-radius: 8px;
            color: #000;
            left: 0;
            top: 100%;
            margin-top: 4px;
            box-shadow: 0 5px 46px #0000001f,0 7px 15px #0000001f;
            height: 300px;
            overflow-y: auto;
        }
        .suggest-list {
            margin: 0;
            padding: 0;
            height: 100%;
            list-style-type: none;
        }
        .suggest-list li {
           padding: 8px 10px 8px 15px;
        }
        .suggest-list li:hover {
            background-color: #f4f4f4;
        }
        .meta {
            display: flex;
            justify-content: space-between;
            margin-top: 24px;
            margin-bottom: 20px;
        }
        .meta-right {
            display: flex;
            align-items: flex-end;
        }
        .sort {
            margin-right: 20px;
        }
        .table {
            background-color: #fff;
            margin-bottom: 20px;
        }
        .row {
            border-top: 1px solid #EEF2F7;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
        }
        .row:nth-child(even) {
            background-color: #F1F1F1;
        }

        .row__header {
            background-color: #B5C3CC;
        }
        .table-item {
            display: block;
            width: calc(100% / 6);
            padding: 9px 15px;
        }
        .table-contact {
            gap: 8px;
            color: #8c969d;
            align-items: center;
            display: flex;
            padding: 9px 15px;
        }
        .page {
            cursor: pointer;
            text-decoration: none;
            line-height: normal;
            font-family: inherit;
            font-size: 1em;
            font-weight: bold;
            width: auto;
            margin: 0;
            height: 34px;
            padding: .5em 1em;
            display: inline-block;
            border: none;
            border-radius: 4px;
            text-align: center;
            vertical-align: middle;
            background-color: #fff;
            color: #48b1ec;
        }
        .page.active {
            cursor: default;
            color: #fff;
            background-color: #48b1ec;
        }
    </style>
    <script>
        function prepareUrlWithQueryParams(formData) {
            let searchParams = new URLSearchParams(window.location.search);
            for(let [name, value] of formData) {
                if (['null', null, ''].includes(value)) {

                    searchParams.delete(name);
                } else {
                    searchParams.set(name, value);
                }
            }

            return searchParams.toString()
        }

        async function getSuggest(name) {
            const response = await fetch(`/api/city-suggest?name=${name}` , {
                "Accept": "application/json",
                "Content-Type": "application/json",
            });
            return await response.json();
        }

        const filter = document.getElementById('filter');

        filter.onsubmit = function(e) {
            e.preventDefault();
            const formData = new FormData(this);

            window.location.search = prepareUrlWithQueryParams(formData);
        }

        const suggestOutsideClick = (event, inputDomElement, suggestListDom) => {
            event.stopPropagation();
            console.log('fs');
            if (!suggestListDom.contains(event.target)) {

            } else {

                inputDomElement.value = event.target.innerText;
                const addressId = document.querySelector(`[name=${inputDomElement.name}Id]`);

                if (!addressId) {
                    inputDomElement.insertAdjacentHTML('afterend', `<input type="hidden" name="${inputDomElement.name}Id" value="${event.target.value}">`);
                } else {
                    addressId.value = event.target.value;
                }
            }

            //document.removeEventListener('click', suggestOutsideClick, { capture: true });
            suggestListDom.style.display = 'none';
        }



        const addDocumentListener = (inputDomElement, suggestListDom) => {
            const handleClick = ev => suggestOutsideClick(ev, inputDomElement, suggestListDom);
            document.removeEventListener('click', handleClick, { capture: true, once: true });
            document.addEventListener('click', handleClick , { capture: true, once: true });
        }

        const handleFilterAddress = async (e, addressInput, addressSuggest, radius) => {
            if (e.target.value) {



                if (e.target.value.length > 1) {
                    const {data} = await getSuggest(e.target.value);
                    radius.disabled = false;
                    const ul = addressSuggest.querySelector('.suggest-list');

                    ul.innerHTML = '';
                    if (data && data.length) {

                        addDocumentListener(fromAddressInput, fromAddressSuggest);
                        let inner = '';
                        data.forEach(el => {
                            inner += `<li value=${el.id}>${el.name}</li>`
                        })

                        ul.insertAdjacentHTML('afterbegin', inner);
                        addressSuggest.style.display = 'flex';

                    } else {
                        addressSuggest.style.display = 'none';
                    }
                } else {
                    addressSuggest.style.display = 'none';
                }
            } else {
                addressSuggest.style.display = 'none';
                radius.disabled = true;
                radius.value = '';
            }
        }

        const fromAddressInput = document.getElementById('fromAddressInput');
        const fromAddressSuggest = document.getElementById('fromAddressSuggest');
        const fromRadius = document.getElementById('fromRadius');

        const toAddressInput = document.getElementById('toAddressInput');
        const toAddressSuggest = document.getElementById('toAddressSuggest');
        const toRadius = document.getElementById('toRadius');

        fromAddressInput.addEventListener('input', e => handleFilterAddress(e, fromAddressInput, fromAddressSuggest, fromRadius));

        toAddressInput.addEventListener('input', e => handleFilterAddress(e, toAddressInput, toAddressSuggest, toRadius));

    </script>
{% endblock %}
